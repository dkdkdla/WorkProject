<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/navy_primary"
            android:padding="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AlbaPass" android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/orange_accent" android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="회원가입" android:textSize="22sp" android:textStyle="bold"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <EditText android:id="@+id/etRegId"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:hint="아이디 *" android:background="#FFF0F4FF"
                    android:paddingHorizontal="14dp" android:layout_marginBottom="10dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:passwordToggleEnabled="true" app:boxBackgroundMode="none"
                    android:layout_marginBottom="10dp">
                    <EditText android:id="@+id/etRegPw"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:hint="비밀번호 *" android:inputType="textPassword"
                        android:background="#FFF0F4FF" android:paddingHorizontal="14dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:passwordToggleEnabled="true" app:boxBackgroundMode="none"
                    android:layout_marginBottom="10dp">
                    <EditText android:id="@+id/etRegPwConfirm"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:hint="비밀번호 확인 *" android:inputType="textPassword"
                        android:background="#FFF0F4FF" android:paddingHorizontal="14dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <EditText android:id="@+id/etRegName"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:hint="이름 *" android:background="#FFF0F4FF"
                    android:paddingHorizontal="14dp" android:layout_marginBottom="10dp"/>

                <EditText android:id="@+id/etRegPhone"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:hint="전화번호 *" android:inputType="phone"
                    android:background="#FFF0F4FF" android:paddingHorizontal="14dp"
                    android:layout_marginBottom="10dp"/>

                <Button android:id="@+id/btnBirthPicker"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="생년월일 선택 *" android:textSize="14sp"
                    android:textColor="#888888" android:backgroundTint="#FFF0F4FF"
                    android:gravity="center_vertical|start" android:paddingHorizontal="14dp"
                    android:layout_marginBottom="10dp"
                    app:strokeColor="#CCCCCC" app:strokeWidth="1dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                <EditText android:id="@+id/etWage"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:hint="시급 (선택)" android:inputType="number"
                    android:background="#FFF0F4FF" android:paddingHorizontal="14dp"
                    android:layout_marginBottom="10dp"/>

                <Button android:id="@+id/btnStoreSearch"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="소속 매장 검색 (선택)" android:textSize="14sp"
                    android:textColor="@color/navy_primary" android:backgroundTint="#FFE8ECFF"
                    android:layout_marginBottom="10dp"
                    app:strokeColor="@color/navy_primary" app:strokeWidth="1dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                <EditText android:id="@+id/etStoreId"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:visibility="gone"/>

                <TextView android:id="@+id/tvAdminNotice"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="점장 가입 신청 후 전체관리자 승인이 완료되면 로그인 가능합니다."
                    android:textColor="#E65100" android:textSize="12sp"
                    android:background="#FFF3E0" android:padding="12dp"
                    android:layout_marginBottom="10dp" android:visibility="gone"/>

                <CheckBox android:id="@+id/chkIsAdmin"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="관리자(점장)로 가입하기" android:textColor="@color/navy_primary"
                    android:textSize="15sp" android:layout_marginBottom="16dp"/>

                <Button android:id="@+id/btnRegisterAction"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:text="가입 완료" android:textSize="16sp" android:textStyle="bold"
                    android:backgroundTint="@color/navy_primary" android:textColor="#FFFFFF"
                    app:cornerRadius="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
