<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/gray_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="30dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="회원가입"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/navy_primary"
            android:layout_marginBottom="30dp"/>

        <EditText
            android:id="@+id/etRegId"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="아이디 *"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="10dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:passwordToggleEnabled="true"
            app:boxBackgroundMode="none"
            android:layout_marginBottom="10dp">

            <EditText
                android:id="@+id/etRegPw"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="비밀번호 *"
                android:inputType="textPassword"
                android:background="@drawable/bg_button_navy"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="20dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:passwordToggleEnabled="true"
            app:boxBackgroundMode="none"
            android:layout_marginBottom="10dp">

            <EditText
                android:id="@+id/etRegPwConfirm"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="비밀번호 확인 *"
                android:inputType="textPassword"
                android:background="@drawable/bg_button_navy"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="20dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <EditText
            android:id="@+id/etRegName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="이름 *"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etRegPhone"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="전화번호 *"
            android:inputType="phone"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etWage"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="시급 (선택)"
            android:inputType="number"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:id="@+id/etStoreId"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="매장 ID (선택)"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#E3F2FD"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etStoreName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="매장 이름 *"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#E3F2FD"
            android:paddingHorizontal="20dp"
            android:visibility="gone"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etAdminCode"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="관리자 인증 코드 *"
            android:inputType="numberPassword"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#FFEBEE"
            android:paddingHorizontal="20dp"
            android:visibility="gone"
            android:layout_marginBottom="10dp"/>

        <CheckBox
            android:id="@+id/chkIsAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="관리자로 가입하기"
            android:textColor="@color/navy_primary"
            android:textSize="16sp"
            android:layout_gravity="left"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="* 표시는 필수 입력 항목입니다."
            android:textColor="#FF5252"
            android:textSize="13sp"
            android:gravity="left"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnRegisterAction"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="가입 완료"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_navy"
            android:textColor="@color/white"
            android:elevation="5dp"/>

    </LinearLayout>
</ScrollView>