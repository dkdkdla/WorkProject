<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/gray_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="30dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="내 정보 수정"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/navy_primary"
            android:layout_marginBottom="30dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="아이디"
            android:textColor="#888888"
            android:layout_marginBottom="5dp"/>
        <EditText
            android:id="@+id/etProId"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#DDDDDD"
            android:enabled="false"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="이름"
            android:textColor="#888888"
            android:layout_marginBottom="5dp"/>
        <EditText
            android:id="@+id/etProName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#DDDDDD"
            android:enabled="false"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="전화번호"
            android:textColor="#555555"
            android:layout_marginBottom="5dp"/>
        <EditText
            android:id="@+id/etProPhone"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="전화번호"
            android:inputType="phone"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="시급"
            android:textColor="#555555"
            android:layout_marginBottom="5dp"/>
        <EditText
            android:id="@+id/etProWage"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="시급"
            android:inputType="number"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="25dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="새 비밀번호 (변경시에만 입력)"
            android:textColor="#FF5722"
            android:textStyle="bold"
            android:layout_marginBottom="5dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:passwordToggleEnabled="true"
            app:boxBackgroundMode="none"
            android:layout_marginBottom="5dp">

            <EditText
                android:id="@+id/etProPw"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="비워두면 변경 안 함"
                android:inputType="textPassword"
                android:background="@drawable/bg_button_navy"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="20dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:passwordToggleEnabled="true"
            app:boxBackgroundMode="none"
            android:layout_marginBottom="30dp">

            <EditText
                android:id="@+id/etProPwConfirm"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="새 비밀번호 확인"
                android:inputType="textPassword"
                android:background="@drawable/bg_button_navy"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="20dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="매장 관리 (등록 / 생성)"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/navy_primary"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="등록된 매장 목록"
            android:textColor="#555555"
            android:layout_marginBottom="5dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvStoreList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_store"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvStoreHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="새 매장 추가하기"
            android:textColor="#555555"
            android:layout_marginBottom="5dp"/>

        <!-- 점장 전용: 매장 이름 입력 -->
        <EditText
            android:id="@+id/etNewStoreName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="매장 이름 (예: 강남점)"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone"/>

        <!-- 점장 전용: 매장 ID 입력 -->
        <EditText
            android:id="@+id/etNewStoreId"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="매장 코드 (예: store01)"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone"/>

        <!-- 점장 전용: 매장 생성 신청 버튼 -->
        <Button
            android:id="@+id/btnCreateStore"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="매장 생성 신청"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_navy"
            android:textColor="@color/white"
            android:layout_marginBottom="10dp"
            android:visibility="gone"/>

        <!-- 직원 전용: 매장 검색 버튼 -->
        <Button
            android:id="@+id/btnStoreSearch"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="소속 매장 검색"
            android:textSize="15sp"
            android:textColor="#1565C0"
            android:backgroundTint="#E3F2FD"
            android:layout_marginBottom="5dp"
            app:strokeColor="#1565C0"
            app:strokeWidth="1dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:visibility="gone"/>

        <!-- 선택된 매장 표시 -->
        <TextView
            android:id="@+id/tvSelectedStore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:layout_marginBottom="5dp"
            android:visibility="gone"/>

        <!-- 직원 전용: 소속 신청 버튼 -->
        <Button
            android:id="@+id/btnJoinStore"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="소속 신청"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_navy"
            android:textColor="@color/white"
            android:layout_marginBottom="30dp"
            android:visibility="gone"/>

        <!-- PENDING 안내 메시지 -->
        <TextView
            android:id="@+id/tvPendingNotice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="소속 신청 후 점장 승인이 완료되면 매장이 활성화됩니다."
            android:textColor="#E65100"
            android:textSize="13sp"
            android:background="#FFF3E0"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnUpdateAction"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="내 정보 수정 완료"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_navy"
            android:textColor="@color/white"/>

    </LinearLayout>
</ScrollView>