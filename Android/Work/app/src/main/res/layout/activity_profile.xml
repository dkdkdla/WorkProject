<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/gray_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="30dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="내 정보 수정"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/navy_primary"
            android:layout_marginBottom="30dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="아이디"
            android:textColor="#888888"
            android:layout_marginBottom="5dp"/>
        <EditText
            android:id="@+id/etProId"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#DDDDDD"
            android:enabled="false"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="이름"
            android:textColor="#888888"
            android:layout_marginBottom="5dp"/>
        <EditText
            android:id="@+id/etProName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#DDDDDD"
            android:enabled="false"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="전화번호"
            android:textColor="#555555"
            android:layout_marginBottom="5dp"/>
        <EditText
            android:id="@+id/etProPhone"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="전화번호"
            android:inputType="phone"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="시급"
            android:textColor="#555555"
            android:layout_marginBottom="5dp"/>
        <EditText
            android:id="@+id/etProWage"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="시급"
            android:inputType="number"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="25dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="새 비밀번호 (변경시에만 입력)"
            android:textColor="#FF5722"
            android:textStyle="bold"
            android:layout_marginBottom="5dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:passwordToggleEnabled="true"
            app:boxBackgroundMode="none"
            android:layout_marginBottom="5dp">

            <EditText
                android:id="@+id/etProPw"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="비워두면 변경 안 함"
                android:inputType="textPassword"
                android:background="@drawable/bg_button_navy"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="20dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:passwordToggleEnabled="true"
            app:boxBackgroundMode="none"
            android:layout_marginBottom="30dp">

            <EditText
                android:id="@+id/etProPwConfirm"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="새 비밀번호 확인"
                android:inputType="textPassword"
                android:background="@drawable/bg_button_navy"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="20dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="매장 관리 (등록 / 생성)"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/navy_primary"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="등록된 매장 목록"
            android:textColor="#555555"
            android:layout_marginBottom="5dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvStoreList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_store"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvStoreHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="새 매장 추가하기"
            android:textColor="#555555"
            android:layout_marginBottom="5dp"/>

        <EditText
            android:id="@+id/etNewStoreName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="매장 이름 (예: 강남점)"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="30dp">

            <EditText
                android:id="@+id/etNewStoreId"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:hint="매장 ID (예: cafe1)"
                android:background="@drawable/bg_button_navy"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="20dp"
                android:layout_marginRight="10dp"/>

            <Button
                android:id="@+id/btnJoinStore"
                android:layout_width="80dp"
                android:layout_height="50dp"
                android:text="등록"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_navy"
                android:textColor="@color/white"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnUpdateAction"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="내 정보 수정 완료"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_navy"
            android:textColor="@color/white"/>

    </LinearLayout>
</ScrollView>