<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/navy_primary"
            android:padding="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AlbaPass" android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/orange_accent" android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="내 정보 수정" android:textSize="22sp" android:textStyle="bold"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- 기본 정보 카드 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="기본 정보" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/navy_primary" android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="아이디" android:textSize="11sp" android:textColor="#6c757d"
                    android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etProId"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:background="#FFE8E8E8" android:enabled="false"
                    android:paddingHorizontal="14dp" android:layout_marginBottom="12dp"
                    android:textColor="#888"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="이름" android:textSize="11sp" android:textColor="#6c757d"
                    android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etProName"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:background="#FFE8E8E8" android:enabled="false"
                    android:paddingHorizontal="14dp" android:layout_marginBottom="12dp"
                    android:textColor="#888"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="전화번호" android:textSize="11sp" android:textColor="#6c757d"
                    android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etProPhone"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:hint="전화번호" android:inputType="phone"
                    android:background="#FFF0F4FF" android:paddingHorizontal="14dp"
                    android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="시급" android:textSize="11sp" android:textColor="#6c757d"
                    android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etProWage"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:hint="시급" android:inputType="number"
                    android:background="#FFF0F4FF" android:paddingHorizontal="14dp"
                    android:layout_marginBottom="0dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 비밀번호 변경 카드 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="비밀번호 변경 (선택)" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/navy_primary" android:layout_marginBottom="14dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:passwordToggleEnabled="true" app:boxBackgroundMode="none"
                    android:layout_marginBottom="10dp">
                    <EditText android:id="@+id/etProPw"
                        android:layout_width="match_parent" android:layout_height="46dp"
                        android:hint="새 비밀번호 (변경시만 입력)"
                        android:inputType="textPassword"
                        android:background="#FFF0F4FF" android:paddingHorizontal="14dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:passwordToggleEnabled="true" app:boxBackgroundMode="none">
                    <EditText android:id="@+id/etProPwConfirm"
                        android:layout_width="match_parent" android:layout_height="46dp"
                        android:hint="새 비밀번호 확인"
                        android:inputType="textPassword"
                        android:background="#FFF0F4FF" android:paddingHorizontal="14dp"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 매장 관리 카드 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="매장 관리" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/navy_primary" android:layout_marginBottom="14dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvStoreList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_store"
                    android:layout_marginBottom="14dp"/>

                <TextView android:id="@+id/tvStoreHelp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="새 매장 추가하기" android:textSize="12sp"
                    android:textColor="#6c757d" android:layout_marginBottom="10dp"/>

                <EditText android:id="@+id/etNewStoreName"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:hint="매장 이름 (예: 강남점)"
                    android:background="#FFF0F4FF" android:paddingHorizontal="14dp"
                    android:layout_marginBottom="8dp" android:visibility="gone"/>

                <EditText android:id="@+id/etNewStoreId"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:hint="매장 코드 (예: store01)"
                    android:background="#FFF0F4FF" android:paddingHorizontal="14dp"
                    android:layout_marginBottom="8dp" android:visibility="gone"/>

                <Button android:id="@+id/btnCreateStore"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:text="매장 생성 신청" android:textSize="14sp" android:textStyle="bold"
                    android:backgroundTint="@color/navy_primary" android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp" android:visibility="gone"
                    app:cornerRadius="10dp"/>

                <Button android:id="@+id/btnStoreSearch"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:text="소속 매장 검색" android:textSize="14sp"
                    android:textColor="@color/navy_primary" android:backgroundTint="#FFE8ECFF"
                    android:layout_marginBottom="6dp" android:visibility="gone"
                    app:strokeColor="@color/navy_primary" app:strokeWidth="1dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                <TextView android:id="@+id/tvSelectedStore"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="" android:textColor="@color/navy_primary" android:textSize="13sp"
                    android:layout_marginBottom="8dp" android:visibility="gone"/>

                <Button android:id="@+id/btnJoinStore"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:text="소속 신청" android:textSize="14sp" android:textStyle="bold"
                    android:backgroundTint="@color/navy_primary" android:textColor="#FFFFFF"
                    android:visibility="gone" app:cornerRadius="10dp"/>

                <TextView android:id="@+id/tvPendingNotice"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="소속 신청 후 점장 승인이 완료되면 매장이 활성화됩니다."
                    android:textColor="#E65100" android:textSize="12sp"
                    android:background="#FFF3E0" android:padding="12dp"
                    android:layout_marginTop="8dp" android:visibility="gone"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 수정 완료 버튼 -->
        <Button android:id="@+id/btnUpdateAction"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:text="내 정보 수정 완료"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/navy_primary"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</ScrollView>