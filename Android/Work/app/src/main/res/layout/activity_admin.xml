<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 상단 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/navy_primary"
            android:padding="28dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AlbaPass"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/orange_accent"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvAdminTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="점장 대시보드"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="매장을 관리하세요"
                android:textSize="13sp"
                android:textColor="#B0BEC5"
                android:layout_marginTop="4dp"/>

            <Button
                android:id="@+id/btnAdminChangeStore"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="매장 변경"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:backgroundTint="#3949AB"
                android:layout_marginTop="16dp"
                app:cornerRadius="18dp"/>
        </LinearLayout>

        <!-- 메뉴 버튼들 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 근태 관리 - 가장 큰 버튼 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnManageWork"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:text="📊  직원 근태 관리"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/navy_primary"
                    app:cornerRadius="16dp"/>
            </androidx.cardview.widget.CardView>

            <!-- 2열 그리드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    android:layout_marginEnd="6dp">

                    <Button
                        android:id="@+id/btnAdminEdit"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:text="👥 직원 관리"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:backgroundTint="#3949AB"
                        app:cornerRadius="16dp"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    android:layout_marginStart="6dp">

                    <Button
                        android:id="@+id/btnGoSalary"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:text="💰 급여 정산"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:backgroundTint="#1cc88a"
                        app:cornerRadius="16dp"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnAdminBoard"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="📢  소통 게시판"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/orange_accent"
                    app:cornerRadius="16dp"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnAdminProfile"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="👤  내 정보 수정"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/navy_primary"
                    android:backgroundTint="@color/white"
                    app:cornerRadius="16dp"/>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnAdminLogout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="로그아웃"
                android:textSize="14sp"
                android:textColor="@color/gray_text"
                android:backgroundTint="#F5F5F5"
                app:cornerRadius="12dp"
                android:layout_marginTop="8dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>