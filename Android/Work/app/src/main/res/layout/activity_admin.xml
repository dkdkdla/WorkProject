<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#E8EAF6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="30dp"
        android:paddingTop="50dp"
        android:paddingBottom="50dp">

        <TextView
            android:id="@+id/tvAdminTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="관리자 모드"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnAdminChangeStore"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="다른 매장 관리하기"
            android:textSize="14sp"
            android:backgroundTint="#7986CB"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btnManageWork"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="직원 근태 관리"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#3F51B5"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="15dp"/>

        <Button
            android:id="@+id/btnAdminEdit"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="직원 목록 / 삭제"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#5C6BC0"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="15dp"/>

        <Button
            android:id="@+id/btnAdminBoard"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="📢 소통 게시판"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="15dp"/>

        <Button
            android:id="@+id/btnAdminProfile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="내 정보 수정"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#5C6BC0"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btnGoSalary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💰 월별 급여 정산"
            android:textSize="18sp"
            android:backgroundTint="#673AB7"
            android:textColor="#ffffff"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnAdminLogout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="로그아웃"
            android:backgroundTint="#B0BEC5"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>