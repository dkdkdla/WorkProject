<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/navy_primary"
        android:padding="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="AlbaPass" android:textSize="13sp" android:textStyle="bold"
            android:textColor="@color/orange_accent" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="월별 급여 정산" android:textSize="22sp" android:textStyle="bold"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">
            <EditText
                android:id="@+id/etSalaryYear"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1.2"
                android:hint="2026"
                android:inputType="number"
                android:gravity="center"
                android:maxLength="4"
                android:textSize="16sp"
                android:background="#FFF0F4FF"
                android:padding="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="년" android:textSize="16sp" android:textColor="#555"
                android:layout_marginHorizontal="6dp"/>
            <EditText
                android:id="@+id/etSalaryMonth"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="0.8"
                android:hint="5"
                android:inputType="number"
                android:gravity="center"
                android:maxLength="2"
                android:textSize="16sp"
                android:background="#FFF0F4FF"
                android:padding="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="월" android:textSize="16sp" android:textColor="#555"
                android:layout_marginStart="6dp" android:layout_marginEnd="12dp"/>
            <Button
                android:id="@+id/btnSalarySearch"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="조회"
                android:textStyle="bold"
                android:backgroundTint="@color/navy_primary"
                android:textColor="#FFFFFF"
                app:cornerRadius="10dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <ListView
        android:id="@+id/lvSalary"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="#F0F0F0"
        android:dividerHeight="1dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"/>
</LinearLayout>
