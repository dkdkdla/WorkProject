<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_bg">

    <!-- 상단 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/navy_primary"
        android:padding="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AlbaPass"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/orange_accent"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvListStoreName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="내 근무 기록"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- 기간 선택 카드 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnStartDate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="시작일"
                android:textSize="13sp"
                android:backgroundTint="#F0F4FF"
                android:textColor="@color/navy_primary"
                android:textStyle="bold"
                app:cornerRadius="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~"
                android:textSize="16sp"
                android:textColor="#6c757d"
                android:paddingHorizontal="8dp"/>

            <Button
                android:id="@+id/btnEndDate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="종료일"
                android:textSize="13sp"
                android:backgroundTint="#F0F4FF"
                android:textColor="@color/navy_primary"
                android:textStyle="bold"
                app:cornerRadius="10dp"/>

            <Button
                android:id="@+id/btnSearch"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="조회"
                android:textSize="13sp"
                android:backgroundTint="@color/navy_primary"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                app:cornerRadius="10dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 급여 요약 카드 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@color/navy_primary">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="예상 급여"
                android:textSize="12sp"
                android:textColor="#B0BEC5"/>

            <TextView
                android:id="@+id/tvTotalPay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기간을 선택하고 조회하세요"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvWageInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기본 시급 적용"
                android:textSize="12sp"
                android:textColor="#B0BEC5"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 근무 기록 리스트 -->
    <ListView
        android:id="@+id/listView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:paddingTop="4dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"/>

</LinearLayout>
