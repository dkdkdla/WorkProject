<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/navy_primary"
        android:padding="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="AlbaPass" android:textSize="13sp" android:textStyle="bold"
            android:textColor="@color/orange_accent" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="기록 수동 추가" android:textSize="22sp" android:textStyle="bold"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="직원 선택" android:textSize="12sp" android:textColor="#6c757d"
                android:textStyle="bold" android:layout_marginBottom="6dp"/>
            <Spinner
                android:id="@+id/spMember"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#FFF0F4FF"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="날짜" android:textSize="12sp" android:textColor="#6c757d"
                android:textStyle="bold" android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/etAddDate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="YYYY-MM-DD"
                android:background="#FFF0F4FF"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="시간" android:textSize="12sp" android:textColor="#6c757d"
                android:textStyle="bold" android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/etAddTime"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="HH:mm:ss"
                android:background="#FFF0F4FF"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="구분" android:textSize="12sp" android:textColor="#6c757d"
                android:textStyle="bold" android:layout_marginBottom="6dp"/>
            <Spinner
                android:id="@+id/spType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#FFF0F4FF"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="20dp"/>

            <Button
                android:id="@+id/btnAddSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="추가하기"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/success"
                android:textColor="#FFFFFF"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
