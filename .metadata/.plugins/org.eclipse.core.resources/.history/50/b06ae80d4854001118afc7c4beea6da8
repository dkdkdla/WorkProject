    private void closeAll(Connection conn, PreparedStatement pstmt, ResultSet rs) {
        if(rs != null) try{ rs.close(); } catch(Exception e){}
        if(pstmt != null) try{ pstmt.close(); } catch(Exception e){}
        DBConn.close(conn);
    }
    
