        try {
            conn = DBConn.getConnection();
            conn.setAutoCommit(false); // 🚨 여러 삭제 작업을 하나로 묶기 위해 트랜잭션 시작

            // 1. 연결 장부(tb_my_stores)에서 해당 사용자의 기록을 먼저 삭제
