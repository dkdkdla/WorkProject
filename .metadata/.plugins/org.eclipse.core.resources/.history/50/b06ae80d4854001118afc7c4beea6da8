            pstmt.setString(1, memId);
            int result = pstmt.executeUpdate();

            conn.commit(); // 모든 삭제 성공 시 확정
            return result > 0;

        } catch (Exception e) {
            try { if(conn != null) conn.rollback(); } catch(Exception ex) {} // 실패 시 롤백
            e.printStackTrace();
            return false;
        } finally {
            DBConn.closeAll(conn, pstmt, null);
        }
